# Stepan-2 infra env — заполнить на сервере (НЕ коммитить реальные значения).
POSTGRES_PASSWORD=change-me
SECRET_KEY=                 # Fernet key: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
BROKER_URL=                # AIbroker base URL (тот же, что у Stepan-1)
BROKER_PROJECT_KEY=        # X-Project-Key для Stepan-2 (отдельный проект в брокере)
BOOTSTRAP_SUPER_ADMIN=     # Telegram id первого super_admin (self-heal вход владельца)

# --- Auth gate (по умолчанию ВЫКЛЮЧЕН) ---
TG_BOT_TOKEN=              # BotFather token — нужен для проверки Telegram Login и алертов
AUTH_ENABLED=false         # true → требовать сессию на /ui и /admin
SESSION_SECRET=            # HMAC-секрет для cookie сессии (пусто → используется SECRET_KEY)
TG_LOGIN_BOT_USERNAME=     # username бота для Telegram Login widget; домен привязать в BotFather /setdomain
